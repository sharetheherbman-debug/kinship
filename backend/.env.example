# =============================================================================
# Amarktai Network – Backend Environment Variables
# Copy this file to .env and fill in your values before starting the server.
# NEVER commit .env to version control.
# =============================================================================

# ---- MongoDB ----------------------------------------------------------------
MONGO_URL=mongodb://localhost:27017
DB_NAME=amarktai

# ---- JWT Authentication -----------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_generate_a_long_random_secret_here
ADMIN_SETUP_SECRET=CHANGE_ME_admin_setup_secret

# ---- OpenAI (AI Assistant) --------------------------------------------------
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ---- Stripe (Payments) ------------------------------------------------------
# Get from https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Twilio (SMS / Phone Tracking) ------------------------------------------
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# ---- App -------------------------------------------------------------------
APP_URL=https://kinship.amarktai.com
